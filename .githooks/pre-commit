#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

# Keep bytecode cache in a writable temp dir to avoid sandbox/macOS cache permission errors.
if [[ -z "${PYTHONPYCACHEPREFIX:-}" ]]; then
  export PYTHONPYCACHEPREFIX="${TMPDIR:-/tmp}/sql2bi-pycache"
fi
mkdir -p "$PYTHONPYCACHEPREFIX" 2>/dev/null || true

# Prevent committing unresolved merge markers.
merge_marker_re='^(<<<<<<< .+|=======|>>>>>>> .+)$'
if command -v rg >/dev/null 2>&1; then
  if rg -n "$merge_marker_re" --glob '!*.lock' >/dev/null 2>&1; then
    echo "[pre-commit] Found unresolved merge conflict markers." >&2
    exit 1
  fi
else
  if grep -RInE "$merge_marker_re" \
    --exclude='*.lock' \
    --exclude-dir='.git' \
    --exclude-dir='node_modules' \
    --exclude-dir='.venv' \
    --exclude-dir='__pycache__' \
    . >/dev/null 2>&1; then
    echo "[pre-commit] Found unresolved merge conflict markers." >&2
    exit 1
  fi
fi

# Validate shell script syntax.
while IFS= read -r sh_file; do
  bash -n "$sh_file"
done < <(find . -type f -name '*.sh' -not -path './.git/*' | sort)

# Validate Python syntax for skill scripts.
py_files=()
while IFS= read -r py_file; do
  py_files+=("$py_file")
done < <(find skills/sql-to-bi-builder/scripts -type f -name '*.py' | sort)

while IFS= read -r py_file; do
  py_files+=("$py_file")
done < <(find services/backend -type f -name '*.py' 2>/dev/null | sort)

if [[ ${#py_files[@]} -gt 0 ]]; then
  python3 -m py_compile "${py_files[@]}"
fi

bash scripts/check-requirements-version.sh

echo "[pre-commit] checks passed"
